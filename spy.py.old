#!/usr/bin/python
# -*- coding: utf-8 -*-

import socket
import json
import os
import sys

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.bind(("127.0.0.1", 9999))

os.system('clear')
print(f"ESPION ACTIF - Port 9999\n\n")

while True:
    data, addr = sock.recvfrom(4096)
    raw_msg = data.decode('utf-8')

    sys.stdout.write(raw_msg)
    sys.stdout.flush()
